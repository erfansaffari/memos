# MemOS Environment Configuration
# Copy this file to .env and fill in your API keys.

# Required: Anthropic API key for Claude Sonnet (responses) and Claude Haiku (agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Weights & Biases API key for experiment logging
# Get yours at https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Optional: W&B project name (defaults to "memos")
WANDB_PROJECT=memos
